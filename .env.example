# GitHub API Token
# Create a token at: https://github.com/settings/tokens
# Required permissions: repo (Full control of private repositories)
EXPO_PUBLIC_GITHUB_TOKEN=your_github_token_here

# GitHub API Configuration
EXPO_PUBLIC_GITHUB_API_BASE_URL=https://api.github.com
EXPO_PUBLIC_GITHUB_REPO_OWNER=your_github_username
EXPO_PUBLIC_GITHUB_REPO_NAME=your_repo_name

# Data File Paths
EXPO_PUBLIC_USERS_FILE_PATH=data/users.json
EXPO_PUBLIC_MENU_FILE_PATH=data/menu.json
EXPO_PUBLIC_ORDERS_FILE_PATH=data/orders.json
EXPO_PUBLIC_BANNERS_FILE_PATH=data/banners.json
EXPO_PUBLIC_BOOKINGS_FILE_PATH=data/bookings.json
EXPO_PUBLIC_CART_FILE_PATH=data/cart.json
EXPO_PUBLIC_DINE_FILE_PATH=data/dine.json
EXPO_PUBLIC_NOTIFICATIONS_FILE_PATH=data/notifications.json

# OpenRouteService API Key (FREE alternative for directions)
# Get your key at: https://openrouteservice.org/dev/#/signup
EXPO_PUBLIC_OPENROUTE_API_KEY=your_openroute_api_key_here
